# =============================================
# WhatsApp Evolution API — Configuração
# =============================================
# Copie para .env e preencha os valores.
# NUNCA suba o .env para o repositório.

# ---- Aplicação ----
NODE_ENV=development
PORT=3000
APP_NAME=WhatsApp Evolution API
APP_URL=https://seu-dominio.vercel.app

# ---- Banco de Dados PostgreSQL ----
# Recomendado: Supabase, Neon, Railway ou Render
DB_HOST=localhost
DB_PORT=5432
DB_NAME=whatsapp_api
DB_USER=postgres
DB_PASSWORD=sua_senha_segura
DB_SSL=true

# ---- Redis ----
# Recomendado: Upstash Redis (grátis, funciona no Vercel)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ---- JWT ----
# Gere com: openssl rand -hex 64
JWT_SECRET=substitua_por_uma_string_aleatoria_longa_e_segura
JWT_EXPIRES_IN=7d

# ---- Evolution API ----
# URL onde a Evolution API está rodando
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=minha-chave-secreta-evolution
EVOLUTION_INSTANCE=minha-instancia

# ---- Rate Limiting ----
RATE_LIMIT_MESSAGES_PER_MINUTE=60
MESSAGE_DELAY_MS=1000

# ---- Scheduler ----
MESSAGE_INTERVAL_MS=300000
SEND_HOUR_START=8
SEND_HOUR_END=20

# ---- Logs ----
LOG_LEVEL=info
LOG_FILE=logs/app.log

# ---- CORS ----
CORS_ORIGIN=*
